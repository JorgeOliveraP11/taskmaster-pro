// Task Management — SQLite datasource and Task model

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Status values: PENDING | COMPLETED (SQLite has no native enum in Prisma)
model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}
